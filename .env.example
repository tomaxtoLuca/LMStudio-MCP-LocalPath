# LMStudio-MCP-Locally — Environment Configuration
# Copy to .env and adjust (optional; lmstudio-mcp.json is recommended on Windows)
#
# Windows path example (semicolon-separated):
# MCP_ALLOWED_PATHS=F:/Documents;F:/Projects

# ── Server (HTTP debug mode only: npm run start:http) ─────
MCP_HOST=127.0.0.1
MCP_PORT=8080

# ── LM Studio connection ───────────────────────────────────
# LM Studio local API (default port 1234)
LM_STUDIO_URL=http://127.0.0.1:1234
# Leave as "local-model" — LM Studio uses whichever model is loaded
LM_STUDIO_MODEL=local-model
LM_CONTEXT_TOKENS=8192
LM_TEMPERATURE=0.1

# ── Security: file access allowlist ───────────────────────
# macOS/Linux: colon-separated. Windows: semicolon-separated (or use lmstudio-mcp.json)
# MCP_ALLOWED_PATHS=/Users/me/Documents:/Users/me/Projects
# MCP_ALLOWED_PATHS=F:/Documents;F:/Projects

# Max file size (bytes) — default 50MB
MCP_MAX_FILE_SIZE=52428800

# Max chars returned per read_file call — default 200K chars
MCP_MAX_CHARS=200000

# Max files returned in list_directory — default 500
MCP_MAX_LIST=500

# Follow symlinks (security risk — keep false)
MCP_FOLLOW_SYMLINKS=false

# Optional: path to config file (also set in ~/.lmstudio/mcp.json env)
# MCP_CONFIG=F:/path/to/lmstudio-mcp.json
# ── Debug ──────────────────────────────────────────────────
# Logs go to stderr in stdio mode (safe for MCP protocol)
MCP_DEBUG=false
