{
  "name": "lmstudio-mcp-local",
  "version": "1.1.0",
  "description": "MCP server for LM Studio — read local file paths on your machine (PDF, DOCX, code, text)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "lmstudio-mcp-local": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "prestart": "npm run build",
    "dev": "npm run build && node --watch dist/index.js",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.5",
    "glob": "^11.0.0",
    "mammoth": "^1.8.0",
    "mime-types": "^2.1.35",
    "pdf-parse": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "lm-studio",
    "mcp",
    "model-context-protocol",
    "local-files",
    "local-ai"
  ],
  "author": "tomaxtoLuca (https://github.com/tomaxtoLuca)",
  "homepage": "https://github.com/tomaxtoLuca/lmstudio-mcp-local#readme",
  "bugs": {
    "url": "https://github.com/tomaxtoLuca/lmstudio-mcp-local/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomaxtoLuca/lmstudio-mcp-local.git"
  }
}
